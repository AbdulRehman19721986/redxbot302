      "fluent-ffmpeg": "$fluent-ffmpeg",
      "file-type": "$file-type",
      "fs-extra": "$fs-extra",
      "node-webpmux": "$node-webpmux"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "contributors": [
    {
      "name": "Abdul Rehman Rajpoot",
      "role": "Lead Developer"
