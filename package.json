{
  "name": "redxbot302",
  "version": "5.2.2",
  "description": "REDXBOT302 – Advanced WhatsApp Bot by Abdul Rehman Rajpoot",
  "main": "index.js",
  "directories": {
    "lib": "lib",
    "data": "data",
    "plugins": "plugins"
  },
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "lint": "node test.js",
