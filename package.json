{
  "name": "redxbot302",
  "version": "10.0.0",
  "description": "REDXBOT302 – Auto-FFmpeg System Enabled",
  "main": "index.js",
  "directories": {
    "lib": "lib",
    "data": "data",
    "plugins": "plugins"
  },
  "scripts": {
    "start": "node index.js",
    "pm2": "pm2-runtime start index.js --name redxbot302",
    "cleanup": "node cleanup.js",
    "install:panel": "npm install --legacy-peer-deps",
    "postinstall": "node -e \"const fs=require('fs'); const path=require('path'); const ffmpegStatic=require('ffmpeg-static'); if(ffmpegStatic && fs.existsSync(ffmpegStatic)) { fs.chmodSync(ffmpegStatic, '755'); const binDir='/app/bin'; if(!fs.existsSync(binDir)) fs.mkdirSync(binDir,{recursive:true}); const symlink=path.join(binDir,'ffmpeg'); try{fs.unlinkSync(symlink)}catch(e){}; fs.symlinkSync(ffmpegStatic, symlink); console.log('✅ FFmpeg symlinked to',symlink); } else { console.warn('⚠️ ffmpeg-static not found'); }\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "whatsapp-bot",
    "baileys-bot",
    "redxbot302"
  ],
  "author": "Abdul Rehman Rajpoot",
  "license": "MIT",
  "dependencies": {
    "@adiwajshing/keyed-db": "^0.2.4",
    "@distube/ytdl-core": "^4.15.8",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@hapi/boom": "^10.0.1",
    "@vitalets/google-translate-api": "^9.2.1",
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "acrcloud": "^1.4.0",
    "adm-zip": "^0.5.16",
    "api-qasim": "^3.2.10",
    "awesome-phonenumber": "^5.9.0",
    "axios": "^1.7.9",
    "better-sqlite3": "^12.5.0",
    "body-parser": "^1.20.2",
    "buffer": "^6.0.3",
    "chalk": "^4.1.2",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.4.5",
    "express": "^5.1.0",
    "fdown-downloader": "^1.0.0",
    "ffmpeg-static": "^5.2.0",
    "file-type": "^16.5.4",
    "file_size_url": "1.0.6",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.3",
