    "express": "^4.22.1",
    "file-type": "^16.5.4",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.1",
    "fs-extra": "^11.2.0",
    "gifted-btns": "^1.0.2",
    "google-tts-api": "^2.0.2",
    "gtts": "^0.2.1",
    "jimp": "^1.6.0",
    "libphonenumber-js": "^1.11.18",
    "megajs": "^1.3.9",
    "moment-timezone": "^0.5.43",
    "mongoose": "^9.0.2",
    "mysql2": "^3.16.0",
    "node-cache": "^5.1.2",
    "node-fetch": "^2.7.0",
    "node-webpmux": "^3.1.0",
    "performance-now": "^2.1.0",
    "pinterest-downloader": "^1.0.6",
    "qrcode": "^1.5.4",
    "sharp": "0.32.6",
