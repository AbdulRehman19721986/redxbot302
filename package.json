{
  "name": "redxbot302",
  "version": "5.2.0",
  "description": "REDXBOT302 – Advanced WhatsApp Bot by Abdul Rehman Rajpoot",
  "main": "index.js",
  "directories": {
    "lib": "lib",
    "data": "data",
    "plugins": "plugins"
  },
  "scripts": {
    "start": "pm2 start index.js --deep-monitoring --attach --name redxbot302",
    "stop": "pm2 stop redxbot302",
    "restart": "pm2 restart redxbot302",
    "node": "node index.js",
    "dev": "nodemon index.js",
    "check": "node -e \"require('syntax-error'); console.log('Syntax checker ready')\"",
    "lint": "node test.js",
    "start:optimized": "node --max-old-space-size=512 --optimize-for-size --gc-interval=100 index.js",
    "cleanup": "node cleanup.js",
    "reset-session": "node reset-session.js",
    "start:clean": "npm run cleanup && npm run start:optimized",
    "install:panel": "npm install --legacy-peer-deps",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "whatsapp-bot",
    "whatsapp-api",
    "baileys-bot",
    "redxbot302",
    "multi-device",
    "redx",
    "khan-md"
  ],
  "homepage": "https://github.com/AbdulRehman19721986/redxbot302",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AbdulRehman19721986/redxbot302.git"
  },
  "bugs": {
    "url": "https://github.com/AbdulRehman19721986/redxbot302/issues"
  },
  "license": "MIT",
  "author": "Abdul Rehman Rajpoot",
  "dependencies": {
    "@adiwajshing/keyed-db": "^0.2.4",
    "@distube/ytdl-core": "^4.15.8",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@hapi/boom": "^10.0.1",
    "@vitalets/google-translate-api": "^9.2.1",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "acrcloud": "^1.4.0",
    "adm-zip": "^0.5.16",
    "api-qasim": "^3.2.10",
    "awesome-phonenumber": "^5.9.0",
    "axios": "^1.7.9",
    "better-sqlite3": "^12.5.0",
    "body-parser": "^1.20.2",
    "buffer": "^6.0.3",
    "chalk": "^4.1.2",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.4.5",
    "express": "^5.1.0",
    "fdown-downloader": "^1.0.0",
    "ffmpeg-static": "^5.2.0",
    "file-type": "^16.5.4",
    "file_size_url": "1.0.6",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.3",
    "fs-extra": "^11.2.0",
    "gifted-btns": "^1.0.2",
    "google-tts-api": "^2.0.2",
    "gtts": "^0.2.1",
    "human-readable": "^0.2.1",
    "jimp": "latest",
    "libphonenumber-js": "^1.11.18",
    "link-preview-js": "^3.0.5",
    "megajs": "^1.3.9",
    "moment-timezone": "^0.6.0",
    "mongoose": "^9.0.2",
    "mumaker": "^2.0.0",
    "mysql2": "^3.16.0",
    "node-cache": "^5.1.2",
    "node-fetch": "^2.7.0",
    "node-id3": "^0.2.6",
    "node-webpmux": "^3.1.0",
    "node-youtube-music": "^0.8.3",
    "performance-now": "^2.1.0",
    "pg": "^8.16.3",
    "pino": "^9.7.0",
    "pinterest-downloader": "^1.0.6",
    "pm2": "^6.0.8",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "ruhend-scraper": "^9.0.8",
    "sharp": "^0.32.6",
    "simple-git": "^3.30.0",
    "syntax-error": "^1.4.0",
    "translate-google-api": "^1.0.4",
    "video-to-audio": "^1.0.0",
    "wa-sticker-formatter": "^4.4.4",
    "wa_set_pkg": "1.0.5",
    "yt-search": "^2.13.1",
    "ytdl-core": "^4.11.5"
  },
  "overrides": {
    "wa-sticker-formatter": {
      "sharp": "$sharp",
      "axios": "$axios",
      "fluent-ffmpeg": "$fluent-ffmpeg",
      "file-type": "$file-type",
      "fs-extra": "$fs-extra",
      "node-webpmux": "$node-webpmux"
    },
    "gtts": {
      "request": {
        "form-data": "^4.0.1",
        "qs": "^6.14.1",
        "tough-cookie": "^4.1.3"
      }
    },
    "jimp": "latest"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "contributors": [
    {
      "name": "Abdul Rehman Rajpoot",
      "role": "Lead Developer"
    },
    {
      "name": "Abdul Rehman Rajpoot",
      "role": "Logic Contributor"
    }
  ]
}
